# ============================================================
# FreelanceDoc — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env with real secrets.
# ============================================================

# ----- Application -----
NODE_ENV=development
PORT=3001

# ----- Database (Supabase / PostgreSQL) -----
# Transaction pooler — used by Prisma at runtime (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection — used by Prisma Migrate (port 5432)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ----- Supabase -----
SUPABASE_URL=https://[project-ref].supabase.co
# WARNING: service role key bypasses RLS — ONLY use server-side, never expose to client
# Must start with 'eyJ' (it is a Supabase-issued JWT)
SUPABASE_SERVICE_KEY=eyJ...

# ----- JWT -----
# Must be at least 256 bits (32+ chars). Generate with: openssl rand -base64 32
JWT_SECRET=change_me_use_openssl_rand_base64_32
# Must be different from JWT_SECRET
JWT_REFRESH_SECRET=change_me_use_openssl_rand_base64_32_different

# JWT token lifetimes (duration strings: s=seconds, m=minutes, h=hours, d=days)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ----- Cookies -----
# Secret used to sign httpOnly cookies — must differ from both JWT secrets
# Generate with: openssl rand -base64 32
COOKIE_SECRET=change_me_use_openssl_rand_base64_32_cookie

# ----- CORS -----
# Exact URL of the Vercel deployment (no trailing slash)
ALLOWED_ORIGIN=http://localhost:3000

# ----- SMTP (Nodemailer) -----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@freelancedoc.app

# ============================================================
# Test-only variables (used by vitest.security.config.ts)
# Point to an isolated Supabase project — NEVER use production
# ============================================================
TEST_SUPABASE_URL=https://[test-project-ref].supabase.co
TEST_SUPABASE_SERVICE_KEY=eyJ...
TEST_DATABASE_URL=postgresql://postgres.[test-project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
TEST_JWT_SECRET=test_jwt_secret_minimum_32_characters_long
